{
  "servers": [
    {
      "name": "test-python-tool",
      "transport": "stdio",
      "command": "python3",
      "args": [
        "/opt/workspace/omni-stack/plugins/tools/.remote/test-python-tool/tools/test-python-tool/server.py"
      ],
      "env": {
        "GREETING_NAME": "Omni"
      },
      "timeout_secs": 900,
      "max_retries": 1,
      "pool_size": 3,
      "allowed_tools": ["*"]
    }
  ]
}
